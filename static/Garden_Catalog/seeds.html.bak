    <div class="letter-title">Y</div>
    <div class="seed-grid">

        <div class="seed-item" onclick="openModal('Yellow Rose', 'https://via.placeholder.com/300', 'Yellow roses are a variety of roses that produce bright yellow blooms, often used in gardens and floral arrangements to symbolize friendship and joy.')">
            <img src="https://via.placeholder.com/300">
            Yellow Rose
        </div>

        <div class="seed-item" onclick="openModal('Yucca', 'https://via.placeholder.com/300', 'Yucca is a flowering plant that produces tall spikes of white or cream-colored blooms, often used in gardens and landscaping, especially in arid regions.')">
            <img src="https://via.placeholder.com/300">
            Yucca
        </div>

        <div class="seed-item" onclick="openModal('Yellow Iris', 'https://via.placeholder.com/300', 'Yellow irises are a variety of irises that produce vibrant yellow blooms, often used in gardens and floral arrangements.')">
            <img src="https://via.placeholder.com/300">
            Yellow Iris
        </div>
    </div>
    </div>

    <!-- Z -->
<div class="letter-section">
    <div class="letter-title">Z</div>
    <div class="seed-grid">

        <div class="seed-item" onclick="openModal('Zinnia', 'https://via.placeholder.com/300', 'Zinnias are flowering plants that produce vibrant blooms in a variety of colors, often used in gardens and floral arrangements.')">
            <img src="https://via.placeholder.com/300">
            Zinnia
        </div>

        <div class="seed-item" onclick="openModal('Zephyranthes', 'https://via.placeholder.com/300', 'Zephyranthes, also known as rain lilies, are flowering plants that produce delicate blooms in shades of pink, white, and yellow, often blooming after rain.')">
            <img src="https://via.placeholder.com/300">
            Zephyranthes
        </div>

        <div class="seed-item" onclick="openModal('Zebra Plant', 'https://via.placeholder.com/300', 'The zebra plant, also known as Aphelandra squarrosa, is a tropical flowering plant that produces striking yellow blooms and has distinctive dark green leaves with white veins.')">
            <img src="https://via.placeholder.com/300">
            Zantedeschia
        </div>
    </div>
    </div>
<!-- Modal -->

<div id="modal">
    <div id="modal-content">
        <img id="modal-img" src="">
        <h2 id="modal-title"></h2>
        <p id="modal-desc"></p>
        <button id="close-btn" onclick="closeModal()">Close</button>
    </div>
</div>

<script>
function openModal(title, img, desc) {
    document.getElementById("modal-title").innerText = title;
    document.getElementById("modal-img").src = img;
    document.getElementById("modal-desc").innerText = desc;
    document.getElementById("modal").style.display = "flex";
}

function closeModal() {
    document.getElementById("modal").style.display = "none";
}
</script>

</body>
</html>
